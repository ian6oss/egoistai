---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  categorySlug: string;
  image: string;
  date: string;
  readTime: string;
}

const { title, slug, excerpt, category, categorySlug, image, date, readTime } = Astro.props;

const categoryBadgeClass: Record<string, string> = {
  tools: 'cat-tools',
  news: 'cat-news',
  tutorials: 'cat-tutorials',
  money: 'cat-money',
  people: 'cat-people',
};

const badgeClass = categoryBadgeClass[categorySlug] || 'cat-tools';

// Generate a filename-like string from the slug
const filename = slug.replace(/\//g, '-') + '.md';
---

<a href={`/articles/${slug}`} class="group block">
  <article class="terminal-card">
    <!-- Terminal title bar -->
    <div class="tbar">
      <div class="dot dot-red"></div>
      <div class="dot dot-yellow"></div>
      <div class="dot dot-green"></div>
      <span class="tbar-title">{filename}</span>
    </div>
    <!-- Card body -->
    <div class="p-4">
      <span class={`cat-badge ${badgeClass} mb-2`}>
        {category.toUpperCase()}
      </span>
      <h3 class="text-[15px] font-semibold leading-[1.45] mb-2 transition-colors group-hover:text-[#da7756]" style="color: #e8e6e3;">
        {title}
      </h3>
      <p class="text-[13px] leading-[1.55] mb-3.5 line-clamp-2" style="color: #a89b8c;">
        {excerpt}
      </p>
      <div class="flex justify-between items-center pt-2.5" style="border-top: 1px solid rgba(80,72,92,0.6); font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #5a5468;">
        <span><span style="color: #da7756;">$ </span>{new Date(date).toLocaleDateString('en-CA')}</span>
        <span>{readTime}</span>
      </div>
    </div>
  </article>
</a>
