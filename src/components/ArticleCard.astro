---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  category: string;
  categorySlug: string;
  image: string;
  date: string;
  readTime: string;
}

const { title, slug, excerpt, category, categorySlug, image, date, readTime } = Astro.props;

const categoryColors: Record<string, string> = {
  tools: 'bg-[var(--color-primary)]/20 text-[var(--color-primary)]',
  news: 'bg-blue-500/20 text-blue-400',
  tutorials: 'bg-purple-500/20 text-purple-400',
  money: 'bg-yellow-500/20 text-yellow-400',
  people: 'bg-pink-500/20 text-pink-400',
};

const badgeClass = categoryColors[categorySlug] || categoryColors.tools;
---

<a href={`/articles/${slug}`} class="group block">
  <article class="card-hover bg-[var(--color-card-bg)] rounded-xl overflow-hidden border border-white/5">
    <!-- Image -->
    <div class="aspect-[16/9] overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
    <!-- Content -->
    <div class="p-5">
      <div class="flex items-center gap-3 mb-3">
        <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-semibold ${badgeClass}`}>
          {category}
        </span>
        <span class="text-xs text-gray-500">{readTime}</span>
      </div>
      <h3 class="text-lg font-bold text-white leading-tight mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
        {title}
      </h3>
      <p class="text-sm text-gray-400 line-clamp-2 mb-3">
        {excerpt}
      </p>
      <time datetime={date} class="text-xs text-gray-500">
        {new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </time>
    </div>
  </article>
</a>
