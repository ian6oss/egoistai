---
interface Props {
  active?: string;
}

const { active } = Astro.props;

const categories = [
  { name: "all", slug: "" },
  { name: "tools", slug: "tools" },
  { name: "news", slug: "news" },
  { name: "tutorials", slug: "tutorials" },
  { name: "money", slug: "money" },
  { name: "people", slug: "people" },
];
---

<div class="flex flex-wrap gap-1.5">
  {categories.map(cat => {
    const isActive = active === cat.slug || (!active && cat.slug === "");
    const href = cat.slug ? `/articles/category/${cat.slug}` : "/";
    return (
      <a
        href={href}
        class:list={[
          "px-3 py-1 rounded text-[11px] transition-all border no-underline",
          isActive
            ? "border-[#da7756] text-[#da7756] bg-[rgba(218,119,86,0.06)]"
            : "border-[rgba(80,72,92,0.6)] text-[#a89b8c] bg-transparent hover:border-[#da7756] hover:text-[#da7756]"
        ]}
        style="font-family: 'JetBrains Mono', monospace;"
      >
        {cat.name}
      </a>
    );
  })}
</div>
