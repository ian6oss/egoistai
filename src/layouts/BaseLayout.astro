---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
}

const {
  title,
  description = "AI Tools, News & Insights for builders, creators, and power users. Reviews, tutorials, and the latest in artificial intelligence.",
  ogImage = "/og-default.webp",
  article = false
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const categories = [
  { name: "tools", slug: "tools" },
  { name: "news", slug: "news" },
  { name: "tutorials", slug: "tutorials" },
  { name: "money", slug: "money" },
  { name: "people", slug: "people" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="EgoistAI RSS Feed" href="/feed.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="author" content="EgoistAI" />
    <meta name="theme-color" content="#da7756" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXX" crossorigin="anonymous"></script>

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QVGN5D5PD8"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QVGN5D5PD8');
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="EgoistAI" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "EgoistAI",
      "url": "https://egoistai.com",
      "logo": "https://egoistai.com/favicon.svg",
      "description": "AI Tools, News & Insights for builders, creators, and power users.",
      "sameAs": [
        "https://twitter.com/egoistai",
        "https://github.com/egoistai"
      ]
    })} />
  </head>
  <body class="min-h-screen flex flex-col" style="background: #1a1a2e;">
    <!-- Terminal Navigation -->
    <nav class="sticky top-0 z-50 border-b" style="background: rgba(26,26,46,0.95); backdrop-filter: blur(16px); border-color: rgba(80,72,92,0.6);">
      <div class="max-w-[1200px] mx-auto h-[52px] px-6 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 no-underline group">
          <span class="font-bold text-base" style="color: #da7756; font-family: 'JetBrains Mono', monospace;">$</span>
          <span class="font-bold text-[15px] tracking-[0.2em] transition-colors group-hover:text-[#da7756]" style="color: #e8e6e3; font-family: 'JetBrains Mono', monospace;">EgoistAI</span>
          <span class="cursor-blink">_</span>
        </a>

        <!-- Nav Links (desktop) -->
        <div class="hidden md:flex gap-0.5">
          {categories.map(cat => (
            <a href={`/articles/category/${cat.slug}`} class="px-3 py-1.5 rounded text-sm transition-all no-underline hover:bg-[rgba(218,119,86,0.08)]" style="color: #a89b8c; font-family: 'JetBrains Mono', monospace;" onmouseover="this.style.color='#e8e6e3'" onmouseout="this.style.color='#a89b8c'">
              <span style="color: #5a5468; margin-right: 2px;">&gt;</span>{cat.name}
            </a>
          ))}
        </div>

        <!-- Subscribe button -->
        <a href="#newsletter" class="text-sm font-semibold px-4 py-2 rounded no-underline transition-all" style="font-family: 'JetBrains Mono', monospace; color: #1a1a2e; background: #da7756;" onmouseover="this.style.boxShadow='0 0 24px rgba(218,119,86,0.15)'" onmouseout="this.style.boxShadow='none'">
          [Subscribe]
        </a>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Terminal Footer -->
    <footer class="border-t py-8 px-6 text-center" style="border-color: rgba(80,72,92,0.6);">
      <p style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #5a5468;">
        <span style="color: #da7756;">&gt;</span> &copy; 2026 EgoistAI <span style="color: #da7756;">|</span> Built for builders <span style="color: #da7756;">|</span> No fluff allowed <span class="cursor-blink">_</span>
      </p>
    </footer>

    <!-- Newsletter Form Handler -->
    <script>
      document.querySelectorAll('form[id^="newsletter-form"]').forEach(form => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const emailInput = (form as HTMLFormElement).querySelector('input[name="email"]') as HTMLInputElement;
          const submitBtn = (form as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;
          const email = emailInput?.value;
          if (!email) return;

          const originalText = submitBtn.textContent;
          submitBtn.textContent = 'Subscribing...';
          submitBtn.disabled = true;

          try {
            const res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email })
            });

            if (res.ok) {
              emailInput.value = '';
              submitBtn.textContent = 'Subscribed!';
              submitBtn.style.opacity = '0.8';
              setTimeout(() => {
                submitBtn.textContent = originalText;
                submitBtn.style.opacity = '';
                submitBtn.disabled = false;
              }, 3000);
            } else {
              throw new Error('Failed');
            }
          } catch {
            const subs = JSON.parse(localStorage.getItem('egoistai_subs') || '[]');
            if (!subs.includes(email)) subs.push(email);
            localStorage.setItem('egoistai_subs', JSON.stringify(subs));

            emailInput.value = '';
            submitBtn.textContent = 'Subscribed!';
            setTimeout(() => {
              submitBtn.textContent = originalText;
              submitBtn.disabled = false;
            }, 3000);
          }
        });
      });
    </script>
  </body>
</html>
