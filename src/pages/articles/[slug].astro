---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(a => a.id !== article.id && a.data.categorySlug === article.data.categorySlug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const categoryBadgeClass: Record<string, string> = {
  tools: 'cat-tools',
  news: 'cat-news',
  tutorials: 'cat-tutorials',
  money: 'cat-money',
  people: 'cat-people',
};

const badgeClass = categoryBadgeClass[article.data.categorySlug] || 'cat-tools';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.excerpt,
  "image": article.data.image,
  "datePublished": article.data.date,
  "author": {
    "@type": "Person",
    "name": article.data.author || "EgoistAI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "EgoistAI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://egoistai.com/favicon.svg"
    }
  }
};
---

<BaseLayout
  title={`${article.data.title} — EgoistAI`}
  description={article.data.excerpt}
  ogImage={article.data.image}
  article={true}
>
  <!-- Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />

  <article class="py-8 md:py-12">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

        <!-- Main Content -->
        <div class="lg:col-span-3">
          <!-- Header -->
          <header class="mb-8">
            <div class="flex items-center gap-3 mb-4">
              <a href={`/articles/category/${article.data.categorySlug}`} class={`cat-badge ${badgeClass} no-underline hover:opacity-80 transition-opacity`}>
                {article.data.category.toUpperCase()}
              </a>
              <span class="text-sm" style="color: #5a5468;">{article.data.readTime}</span>
            </div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black leading-tight mb-4" style="color: #e8e6e3;">
              {article.data.title}
            </h1>
            <p class="text-lg mb-6" style="color: #a89b8c;">{article.data.excerpt}</p>
            <div class="flex items-center gap-4 text-sm pb-6" style="border-bottom: 1px solid rgba(80,72,92,0.6); color: #5a5468;">
              <span>By <strong style="color: #a89b8c;">{article.data.author || 'EgoistAI'}</strong></span>
              <span>&middot;</span>
              <time datetime={article.data.date} style="font-family: 'JetBrains Mono', monospace; font-size: 12px;">
                <span style="color: #da7756;">$ </span>{new Date(article.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
          </header>

          <!-- Featured Image -->
          {article.data.image && (
            <div class="mb-8 rounded-lg overflow-hidden" style="border: 1px solid rgba(80,72,92,0.6);">
              <img
                src={article.data.image}
                alt={article.data.title}
                class="w-full h-auto"
                width="800"
                height="450"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                style="aspect-ratio: 16/9;"
              />
            </div>
          )}

          <!-- Article Body -->
          <div class="prose prose-lg max-w-none">
            <Content />
          </div>

          <!-- Sources -->
          {article.data.sources && article.data.sources.length > 0 && (
            <div class="mt-10 p-6 rounded-lg" style="background: #1a1a2e; border: 1px solid rgba(80,72,92,0.6);">
              <h3 class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: #5a5468; font-family: 'JetBrains Mono', monospace;">Sources</h3>
              <ul class="space-y-2">
                {article.data.sources.map((source: { name: string; url: string }) => (
                  <li>
                    <a href={source.url} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline" style="color: #da7756;">
                      {source.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Ad Slot: After Content -->
          <div class="my-8 ad-slot py-6">
            <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
          </div>

          <!-- Share Buttons -->
          <div class="py-6 mb-8" style="border-top: 1px solid rgba(80,72,92,0.6); border-bottom: 1px solid rgba(80,72,92,0.6);">
            <h3 class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: #5a5468; font-family: 'JetBrains Mono', monospace;">Share this article</h3>
            <div class="flex gap-3">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(`https://egoistai.com/articles/${article.id}`)}`}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-2 px-4 py-2 rounded text-sm transition-all no-underline"
                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(80,72,92,0.6); color: #a89b8c; font-family: 'JetBrains Mono', monospace; font-size: 12px;"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Tweet
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://egoistai.com/articles/${article.id}`)}`}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-2 px-4 py-2 rounded text-sm transition-all no-underline"
                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(80,72,92,0.6); color: #a89b8c; font-family: 'JetBrains Mono', monospace; font-size: 12px;"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <button
                onclick="navigator.clipboard.writeText(window.location.href); this.textContent = 'Copied!';"
                class="flex items-center gap-2 px-4 py-2 rounded text-sm transition-all cursor-pointer"
                style="background: rgba(255,255,255,0.03); border: 1px solid rgba(80,72,92,0.6); color: #a89b8c; font-family: 'JetBrains Mono', monospace; font-size: 12px;"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
                Copy Link
              </button>
            </div>
          </div>

          <!-- Newsletter CTA -->
          <div class="rounded-lg p-8 mb-8 text-center" style="background: linear-gradient(135deg, #1a1a2e 0%, rgba(218,119,86,0.08) 100%); border: 1px solid rgba(218,119,86,0.3);">
            <h3 class="text-2xl font-bold mb-2" style="color: #e8e6e3; font-family: 'JetBrains Mono', monospace;">
              <span style="color: #da7756;">&gt;</span> Want more like this?
            </h3>
            <p class="text-sm mb-4" style="color: #a89b8c;">Get the best AI insights delivered weekly.</p>
            <form id="newsletter-form-article" class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                required
                class="flex-1 px-4 py-2.5 rounded text-sm focus:outline-none"
                style="background: rgba(255,255,255,0.05); border: 1px solid rgba(80,72,92,0.6); color: #e8e6e3; font-family: 'JetBrains Mono', monospace;"
              />
              <button type="submit" class="px-5 py-2.5 rounded text-sm font-bold transition-colors whitespace-nowrap" style="background: #da7756; color: #12121f; font-family: 'JetBrains Mono', monospace;">
                [Subscribe]
              </button>
            </form>
          </div>

          <!-- Ad Slot: Before Related -->
          <div class="my-8 ad-slot py-6">
            <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
          </div>

          <!-- Related Articles -->
          {relatedArticles.length > 0 && (
            <section>
              <h2 class="text-2xl font-black mb-6" style="color: #e8e6e3; font-family: 'JetBrains Mono', monospace;">
                <span style="color: #da7756;">&gt;</span> Related Articles
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {relatedArticles.map(related => (
                  <ArticleCard
                    title={related.data.title}
                    slug={related.id}
                    excerpt={related.data.excerpt}
                    category={related.data.category}
                    categorySlug={related.data.categorySlug}
                    image={related.data.image}
                    date={related.data.date}
                    readTime={related.data.readTime}
                  />
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-20 space-y-6">
            <!-- Tags -->
            {article.data.tags && article.data.tags.length > 0 && (
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-wider mb-3" style="color: #5a5468; font-family: 'JetBrains Mono', monospace;">Tags</h3>
                <div class="flex flex-wrap gap-2">
                  {article.data.tags.map((tag: string) => (
                    <span class="px-3 py-1 rounded text-xs" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(80,72,92,0.6); color: #a89b8c; font-family: 'JetBrains Mono', monospace;">{tag}</span>
                  ))}
                </div>
              </div>
            )}

            <!-- Ad Slot: Sidebar -->
            <div class="ad-slot p-4 min-h-[250px]">
              <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="vertical" data-full-width-responsive="true"></ins>
            </div>

            <!-- Newsletter -->
            <div class="p-5 rounded-lg" style="background: #1a1a2e; border: 1px solid rgba(80,72,92,0.6);">
              <h3 class="font-bold mb-2" style="color: #e8e6e3; font-family: 'JetBrains Mono', monospace; font-size: 14px;">
                <span style="color: #da7756;">&gt;</span> Stay in the loop
              </h3>
              <p class="text-xs mb-3" style="color: #5a5468;">Weekly AI tools & insights.</p>
              <form id="newsletter-form-article-sidebar" class="flex flex-col gap-2">
                <input
                  type="email"
                  name="email"
                  placeholder="your@email.com"
                  required
                  class="px-3 py-2 rounded text-sm focus:outline-none"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(80,72,92,0.6); color: #e8e6e3; font-family: 'JetBrains Mono', monospace;"
                />
                <button type="submit" class="px-4 py-2 rounded text-sm font-bold transition-colors" style="background: #da7756; color: #12121f; font-family: 'JetBrains Mono', monospace;">
                  [Subscribe]
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
