---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter(a => a.id !== article.id && a.data.categorySlug === article.data.categorySlug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  tools: 'bg-[var(--color-primary)]/20 text-[var(--color-primary)]',
  news: 'bg-blue-500/20 text-blue-400',
  tutorials: 'bg-purple-500/20 text-purple-400',
  money: 'bg-yellow-500/20 text-yellow-400',
  people: 'bg-pink-500/20 text-pink-400',
};

const badgeClass = categoryColors[article.data.categorySlug] || categoryColors.tools;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.excerpt,
  "image": article.data.image,
  "datePublished": article.data.date,
  "author": {
    "@type": "Person",
    "name": article.data.author || "EgoistAI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "EgoistAI",
    "logo": {
      "@type": "ImageObject",
      "url": "https://egoistai.com/favicon.svg"
    }
  }
};
---

<BaseLayout
  title={`${article.data.title} — EgoistAI`}
  description={article.data.excerpt}
  ogImage={article.data.image}
  article={true}
>
  <!-- Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />

  <article class="py-8 md:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

        <!-- Main Content -->
        <div class="lg:col-span-3">
          <!-- Header -->
          <header class="mb-8">
            <div class="flex items-center gap-3 mb-4">
              <a href={`/articles/category/${article.data.categorySlug}`} class={`px-3 py-1 rounded-full text-xs font-semibold ${badgeClass} hover:opacity-80 transition-opacity`}>
                {article.data.category}
              </a>
              <span class="text-sm text-gray-500">{article.data.readTime}</span>
            </div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white leading-tight mb-4">
              {article.data.title}
            </h1>
            <p class="text-lg text-gray-400 mb-6">{article.data.excerpt}</p>
            <div class="flex items-center gap-4 text-sm text-gray-500 pb-6 border-b border-white/5">
              <span>By <strong class="text-gray-300">{article.data.author || 'EgoistAI'}</strong></span>
              <span>&middot;</span>
              <time datetime={article.data.date}>
                {new Date(article.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
          </header>

          <!-- Featured Image -->
          {article.data.image && (
            <div class="mb-8 rounded-xl overflow-hidden">
              <img src={article.data.image} alt={article.data.title} class="w-full h-auto" />
            </div>
          )}

          <!-- Article Body -->
          <div class="prose prose-lg max-w-none">
            <Content />
          </div>

          <!-- Sources -->
          {article.data.sources && article.data.sources.length > 0 && (
            <div class="mt-10 p-6 bg-[var(--color-card-bg)] rounded-xl border border-white/5">
              <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Sources</h3>
              <ul class="space-y-2">
                {article.data.sources.map((source: { name: string; url: string }) => (
                  <li>
                    <a href={source.url} target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-primary)] hover:underline">
                      {source.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Ad Slot: After Content -->
          <div class="my-8 ad-slot py-6">
            <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
          </div>

          <!-- Share Buttons -->
          <div class="py-6 border-t border-b border-white/5 mb-8">
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Share this article</h3>
            <div class="flex gap-3">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(`https://egoistai.com/articles/${article.id}`)}`}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-400 hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/30 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Tweet
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://egoistai.com/articles/${article.id}`)}`}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-400 hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/30 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <button
                onclick="navigator.clipboard.writeText(window.location.href); this.textContent = 'Copied!';"
                class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-gray-400 hover:text-[var(--color-primary)] hover:border-[var(--color-primary)]/30 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
                Copy Link
              </button>
            </div>
          </div>

          <!-- Newsletter CTA -->
          <div class="gradient-cta rounded-2xl p-8 mb-8 text-center">
            <h3 class="text-2xl font-bold text-white mb-2">Want more like this?</h3>
            <p class="text-white/80 text-sm mb-4">Get the best AI insights delivered weekly.</p>
            <form id="newsletter-form-article" class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                required
                class="flex-1 px-4 py-2.5 rounded-lg text-gray-900 bg-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-white/50 text-sm"
              />
              <button type="submit" class="px-5 py-2.5 bg-[var(--color-secondary)] text-[var(--color-primary)] text-sm font-bold rounded-lg hover:bg-[var(--color-secondary)]/90 transition-colors whitespace-nowrap">
                Subscribe
              </button>
            </form>
          </div>

          <!-- Ad Slot: Before Related -->
          <div class="my-8 ad-slot py-6">
            <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
          </div>

          <!-- Related Articles -->
          {relatedArticles.length > 0 && (
            <section>
              <h2 class="text-2xl font-black text-white mb-6">Related Articles</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {relatedArticles.map(related => (
                  <ArticleCard
                    title={related.data.title}
                    slug={related.id}
                    excerpt={related.data.excerpt}
                    category={related.data.category}
                    categorySlug={related.data.categorySlug}
                    image={related.data.image}
                    date={related.data.date}
                    readTime={related.data.readTime}
                  />
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-20 space-y-6">
            <!-- Tags -->
            {article.data.tags && article.data.tags.length > 0 && (
              <div>
                <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Tags</h3>
                <div class="flex flex-wrap gap-2">
                  {article.data.tags.map((tag: string) => (
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs text-gray-400">{tag}</span>
                  ))}
                </div>
              </div>
            )}

            <!-- Ad Slot: Sidebar -->
            <div class="ad-slot p-4 min-h-[250px]">
              <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="vertical" data-full-width-responsive="true"></ins>
            </div>

            <!-- Newsletter -->
            <div class="p-5 bg-[var(--color-card-bg)] rounded-2xl border border-white/5">
              <h3 class="font-bold text-white mb-2">Stay in the loop</h3>
              <p class="text-xs text-gray-500 mb-3">Weekly AI tools & insights.</p>
              <form id="newsletter-form-article-sidebar" class="flex flex-col gap-2">
                <input
                  type="email"
                  name="email"
                  placeholder="your@email.com"
                  required
                  class="px-3 py-2 rounded-lg text-sm bg-white/5 border border-white/10 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-[var(--color-primary)]/50"
                />
                <button type="submit" class="px-4 py-2 bg-[var(--color-primary)] text-[var(--color-secondary)] text-sm font-bold rounded-lg hover:bg-[var(--color-primary)]/90 transition-colors">
                  Subscribe Free
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
