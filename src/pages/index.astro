---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featuredArticle = articles.find(a => a.data.featured) || articles[0];
const latestArticles = articles.filter(a => a.id !== featuredArticle?.id).slice(0, 6);
const popularArticles = articles.slice(0, 5);

const categories = [
  { name: "Tools", slug: "tools" },
  { name: "News", slug: "news" },
  { name: "Tutorials", slug: "tutorials" },
  { name: "Money", slug: "money" },
  { name: "People", slug: "people" },
];
---

<BaseLayout title="EgoistAI — AI Tools, News & Insights for Builders">

  <!-- Hero: Featured Article -->
  {featuredArticle && (
    <section class="gradient-hero border-b border-white/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
        <a href={`/articles/${featuredArticle.id}`} class="block relative rounded-2xl overflow-hidden group bg-[var(--color-card-bg)] border border-white/5 card-hover">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="aspect-[16/9] lg:aspect-auto lg:min-h-[400px] overflow-hidden">
              <img
                src={featuredArticle.data.image}
                alt={featuredArticle.data.title}
                width="800"
                height="450"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="eager"
                fetchpriority="high"
              />
            </div>
            <div class="p-6 md:p-10 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-4">
                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[var(--color-primary)]/20 text-[var(--color-primary)]">
                  Featured
                </span>
                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-white/5 text-gray-400">
                  {featuredArticle.data.category}
                </span>
              </div>
              <h1 class="text-2xl md:text-4xl font-black text-white leading-tight mb-3 group-hover:text-[var(--color-primary)] transition-colors">
                {featuredArticle.data.title}
              </h1>
              <p class="text-gray-400 mb-4 text-base md:text-lg line-clamp-3">{featuredArticle.data.excerpt}</p>
              <div class="flex items-center gap-3 text-sm text-gray-500">
                <span>{featuredArticle.data.readTime}</span>
                <span>&middot;</span>
                <time datetime={featuredArticle.data.date}>
                  {new Date(featuredArticle.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <span class="inline-flex items-center gap-2 mt-6 text-[var(--color-primary)] font-semibold text-sm group-hover:gap-3 transition-all">
                Read article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </div>
        </a>
        <p class="text-center text-gray-500 text-sm mt-6 max-w-2xl mx-auto">
          AI tools, news & insights for builders, creators, and power users. No fluff — just signal.
        </p>
      </div>
    </section>
  )}

  <!-- Ad Slot: Top Banner -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="ad-slot py-4">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="auto" data-full-width-responsive="true"></ins>
    </div>
  </div>

  <!-- Main Content: Articles Grid + Sidebar -->
  <section id="articles" class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

        <!-- Articles Grid (3 cols) -->
        <div class="lg:col-span-3">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
            <h2 class="text-2xl font-black text-white">Latest Articles</h2>
            <CategoryFilter />
          </div>
          {latestArticles.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
              {latestArticles.map(article => (
                <ArticleCard
                  title={article.data.title}
                  slug={article.id}
                  excerpt={article.data.excerpt}
                  category={article.data.category}
                  categorySlug={article.data.categorySlug}
                  image={article.data.image}
                  date={article.data.date}
                  readTime={article.data.readTime}
                />
              ))}
            </div>
          ) : (
            <div class="text-center py-20">
              <div class="text-6xl mb-4">&#x1f4e1;</div>
              <h3 class="text-xl font-bold text-white mb-2">Coming Soon</h3>
              <p class="text-gray-400">Fresh AI content is on its way. Subscribe to get notified.</p>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-20 space-y-8">
            <!-- Popular Articles -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Popular</h3>
              <div class="flex flex-col gap-4">
                {popularArticles.map((article, i) => (
                  <a href={`/articles/${article.id}`} class="flex gap-3 group">
                    <span class="text-2xl font-black text-gray-700 group-hover:text-[var(--color-primary)] transition-colors w-8 shrink-0">
                      {i + 1}
                    </span>
                    <div>
                      <h4 class="text-sm font-semibold text-gray-300 group-hover:text-[var(--color-primary)] transition-colors leading-tight line-clamp-2">
                        {article.data.title}
                      </h4>
                      <span class="text-xs text-gray-600 mt-1">{article.data.category} &middot; {article.data.readTime}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <!-- Newsletter CTA -->
            <div class="p-5 bg-[var(--color-card-bg)] rounded-2xl border border-white/5">
              <h3 class="font-bold text-white mb-2">Never miss a drop</h3>
              <p class="text-xs text-gray-500 mb-3">Weekly AI tools & insights, straight to your inbox.</p>
              <form id="newsletter-form-sidebar" class="flex flex-col gap-2">
                <input
                  type="email"
                  name="email"
                  placeholder="your@email.com"
                  required
                  class="px-3 py-2 rounded-lg text-sm bg-white/5 border border-white/10 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-[var(--color-primary)]/50"
                />
                <button type="submit" class="px-4 py-2 bg-[var(--color-primary)] text-[var(--color-secondary)] text-sm font-bold rounded-lg hover:bg-[var(--color-primary)]/90 transition-colors">
                  Subscribe Free
                </button>
              </form>
              <p class="text-[10px] text-gray-600 mt-2">No spam. Unsubscribe anytime.</p>
            </div>

            <!-- Categories -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Categories</h3>
              <div class="flex flex-col gap-1">
                {categories.map(cat => (
                  <a href={`/articles/category/${cat.slug}`} class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-white/5 text-sm text-gray-400 hover:text-[var(--color-primary)] transition-colors">
                    <span>{cat.name}</span>
                  </a>
                ))}
              </div>
            </div>

            <!-- Ad Slot: Sidebar -->
            <div class="ad-slot p-4">
              <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXXXXXXXX" data-ad-slot="XXXXXXXXXX" data-ad-format="vertical" data-full-width-responsive="true"></ins>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
